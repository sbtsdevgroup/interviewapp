FROM python:3.11-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    httpx \
    pydantic

# Copy API server
COPY analysis-api.py /app/

# Expose port
EXPOSE 8002

# Run the API server
CMD ["uvicorn", "analysis-api:app", "--host", "0.0.0.0", "--port", "8002"]

