FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    ffmpeg \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install --no-cache-dir \
    openai-whisper \
    fastapi \
    uvicorn \
    python-multipart \
    aiofiles \
    --timeout=300

# Copy API server
COPY whisper-api.py /app/

# Expose port
EXPOSE 8001

# Run the API server
CMD ["uvicorn", "whisper-api:app", "--host", "0.0.0.0", "--port", "8001"]

