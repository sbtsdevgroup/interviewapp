{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/assessments/layout,_N_T_/dashboard/assessments/page,_N_T_/dashboard/assessments"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/assessments/__PAGE__",
    "/dashboard/assessments",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}